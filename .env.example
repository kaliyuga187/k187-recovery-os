# Database (SQLite). The scanner auto-creates data/ in the workspace root.
DATABASE_URL=file:../../data/k187.db

# AI provider (optional). If unset, scanner uses heuristic-only "noop" provider.
K187_AI_PROVIDER=minimax-m3
MINIMAX_BASE_URL=https://api.minimax.example/v1
MINIMAX_API_KEY=

# Verbose DB query logging
# K187_DB_LOG=1
