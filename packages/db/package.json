{
  "name": "@k187/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:seed": "tsx ./src/seed.ts",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  },
  "devDependencies": {
    "prisma": "5.22.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
