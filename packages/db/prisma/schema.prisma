// Prisma schema for K187 Recovery OS
// All data is local-first; SQLite is the only store.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id                 String   @id @default(cuid())
  slug               String   @unique
  name               String
  path               String
  source             String   // "local" | "github" | "zip" | "imported"
  category           String
  stack              String   // JSON array
  description        String?
  sizeBytes          Int      @default(0)
  fileCount          Int      @default(0)
  hasGit             Boolean  @default(false)
  hasReadme          Boolean  @default(false)
  hasEnv             Boolean  @default(false)
  hasTests           Boolean  @default(false)
  hasDocker          Boolean  @default(false)
  hasCi              Boolean  @default(false)
  hasDeployGuide     Boolean  @default(false)
  hasBuildArtifacts  Boolean  @default(false)
  lastModified       DateTime?
  firstSeen          DateTime @default(now())
  completionScore    Int      @default(0)
  deployScore        Int      @default(0)
  healthScore        Int      @default(0)
  compositeScore     Int      @default(0)
  status             String   @default("active") // active | paused | complete | abandoned | stuck
  notes              String?
  tags               String   @default("[]") // JSON array
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  scanRuns           ScanResult[]
  analyses           AIAnalysis[]

  @@index([category])
  @@index([status])
  @@index([compositeScore])
}

model ScanResult {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rootPath        String
  scannedAt       DateTime @default(now())
  durationMs      Int      @default(0)
  filesScanned    Int      @default(0)
  errorMessage    String?

  @@index([projectId])
}

model DuplicateGroup {
  id              String   @id @default(cuid())
  fingerprint     String   @unique
  projectIds      String   // JSON array
  recommendation  String   // keep | merge | archive
  reason          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AIAnalysis {
  id                  String   @id @default(cuid())
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  modelUsed           String
  summary             String
  recommendedAction   String
  rationale           String
  nextSteps           String   // JSON array
  risks               String   // JSON array
  generatedAt         DateTime @default(now())

  @@index([projectId])
}

model ActiveBuild {
  id          String   @id @default(cuid())
  projectId   String
  setAt       DateTime @default(now())
  reason      String?
  isPaused    Boolean  @default(false)
}

model Settings {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// WorkLog — one row per completed action across all agents + Kai.
/// "what got done" — commits, deploys, analyses, scans, file edits.
/// Source of truth for the /works dashboard page.
model WorkLog {
  id          String   @id @default(cuid())
  // Categorization
  kind        String   // commit | deploy | scan | analysis | fix | docs | stripe | github | other
  // What was done, human-readable (1-2 lines)
  title       String
  // Longer detail (markdown)
  detail      String?
  // Where it happened
  repoSlug    String?  // optional FK to a Project.slug; null if not tied to one
  // Where in the workspace
  workspacePath String?
  // Files touched (JSON array of paths)
  filesTouched String   @default("[]")
  // Outcome — ok | warn | fail
  outcome     String   @default("ok")
  // When
  performedAt DateTime @default(now())
  // Who did it — kai | hermes | claude-code | codex | openai | minimax-m3
  performedBy String   @default("hermes")
  // GitHub PR/Issue/Commit ref if applicable
  githubRef   String?
  // Cost in cents (for AI calls)
  costCents   Int      @default(0)
  // Free-form tags
  tags        String   @default("[]")

  @@index([performedAt])
  @@index([repoSlug])
  @@index([performedBy])
  @@index([kind])
}

/// AgentRun — one row per invocation of an external agent (Claude Code, Codex, subagent).
/// "what agents are doing" — captures intent, prompt summary, outcome.
/// Source of truth for the /agents dashboard page.
model AgentRun {
  id          String   @id @default(cuid())
  // Which agent
  agentKind   String   // claude-code | codex | openai | subagent | minimax-m3
  agentName   String   // human label, e.g. "delegation-2026-06-25-fix-cliff"
  // Intent — what it was supposed to do
  intent      String
  // The prompt (truncated to first 500 chars to avoid bloat)
  promptSummary String
  // Outcome
  status      String   @default("pending") // pending | running | success | fail | timeout
  // Output (truncated)
  outputSummary String?
  // Cost
  costCents   Int      @default(0)
  // Timing
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  // Who delegated
  delegatedBy String   @default("hermes")
  // Files written (JSON array)
  filesWritten String  @default("[]")
  // Free-form notes
  notes       String?

  @@index([startedAt])
  @@index([agentKind])
  @@index([status])
}

/// Session — one row per Hermes/Hermes-agent session.
/// Tracks what happened across a single user-facing conversation.
/// Source of truth for /session page.
model Session {
  id           String   @id @default(cuid())
  // Compact session id from the runtime
  sessionId    String   @unique
  // When
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  // The first user message (so we can identify sessions in lists)
  firstPrompt  String?
  // What was accomplished (markdown summary)
  summary      String?
  // Number of tool calls
  toolCallCount Int     @default(0)
  // WorkLogs produced (JSON array of WorkLog IDs)
  workLogIds   String   @default("[]")
  // User-visible meta
  platform     String   @default("telegram") // telegram | tui | api | other
  userLabel    String?

  @@index([startedAt])
  @@index([sessionId])
}
