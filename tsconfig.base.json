{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@k187/shared": ["./packages/shared/src/index.ts"],
      "@k187/shared/*": ["./packages/shared/src/*"],
      "@k187/db": ["./packages/db/src/index.ts"],
      "@k187/db/*": ["./packages/db/src/*"],
      "@k187/ai": ["./packages/ai/src/index.ts"],
      "@k187/ai/*": ["./packages/ai/src/*"]
    }
  }
}
